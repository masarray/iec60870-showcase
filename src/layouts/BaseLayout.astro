---
import "@/styles/global.css";
import { siteConfig } from "@/content/site";

export interface Props {
  pageTitle?: string;
  pageDescription?: string;
}

const {
  pageTitle = siteConfig.siteName,
  pageDescription = siteConfig.siteDescription
} = Astro.props;

const keywords = siteConfig.keywords.join(", ");
const baseUrl = import.meta.env.BASE_URL;

// Fallback aman untuk CI/build
const siteOrigin =
  (Astro.site && Astro.site.toString()) || "https://masarray.github.io";

const normalizedBase = baseUrl.endsWith("/") ? baseUrl : `${baseUrl}/`;
const normalizedOgPath = siteConfig.ogImage.replace(/^\/+/, "");

const faviconUrl = `${normalizedBase}favicon.svg`;
const canonicalUrl = new URL(Astro.url.pathname, siteOrigin);
const ogImageUrl = new URL(`${normalizedBase}${normalizedOgPath}`, siteOrigin);
---

<!DOCTYPE html>
<html lang="en" id="top">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="keywords" content={keywords} />
    <meta name="theme-color" content="#f5f9fd" />
    <link rel="canonical" href={canonicalUrl.toString()} />
    <link rel="icon" href={faviconUrl} />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl.toString()} />
    <meta property="og:image" content={ogImageUrl.toString()} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageUrl.toString()} />
  </head>
  <body>
    <slot />
  </body>
</html>