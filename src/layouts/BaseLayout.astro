---
import "@/styles/global.css";
import { siteConfig } from "@/content/site";

export interface Props {
  pageTitle?: string;
  pageDescription?: string;
  pageImage?: string;
  robots?: string;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  pageTitle = siteConfig.siteName,
  pageDescription = siteConfig.siteDescription,
  pageImage = siteConfig.ogImage,
  robots = "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1",
  structuredData = []
} = Astro.props;

const keywords = siteConfig.keywords.join(", ");
const baseUrl = import.meta.env.BASE_URL;
const siteOrigin =
  (Astro.site && Astro.site.toString()) || siteConfig.siteUrl;

const normalizedBase = baseUrl.endsWith("/") ? baseUrl : `${baseUrl}/`;
const normalizedOgPath = pageImage.replace(/^\/+/, "");

const faviconUrl = `${normalizedBase}favicon.svg`;
const canonicalUrl = new URL(Astro.url.pathname, siteOrigin);
const ogImageUrl = new URL(`${normalizedBase}${normalizedOgPath}`, siteOrigin);
const structuredDataItems = Array.isArray(structuredData)
  ? structuredData
  : [structuredData];
---

<!DOCTYPE html>
<html lang="en" id="top">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content={siteConfig.authorName} />
    <meta name="robots" content={robots} />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content="#f5f9fd" />
    <link rel="canonical" href={canonicalUrl.toString()} />
    <link rel="icon" href={faviconUrl} />

    <meta property="og:site_name" content={siteConfig.siteName} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl.toString()} />
    <meta property="og:image" content={ogImageUrl.toString()} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageUrl.toString()} />

    {structuredDataItems
      .filter((item) => Object.keys(item).length > 0)
      .map((item) => (
        <script type="application/ld+json" set:html={JSON.stringify(item)} />
      ))}
  </head>
  <body>
    <slot />
  </body>
</html>
