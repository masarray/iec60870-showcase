---
interface Props {
  src: string;
  alt?: string;
  label?: string;
}

const {
  src,
  alt = "",
  label = "Open full preview"
} = Astro.props;

const modalId = `preview-${Math.random().toString(36).slice(2, 10)}`;
---

<div class="wp-lightbox" data-preview-root data-preview-id={modalId}>
  <button
    type="button"
    class="wp-lightbox__link"
    data-preview-open
    aria-label={label}
    aria-controls={modalId}
  >
    {label}
  </button>

  <div
    class="wp-lightbox__overlay"
    data-preview-overlay
    data-preview-overlay-id={modalId}
    hidden
  >
    <button
      type="button"
      class="wp-lightbox__backdrop"
      data-preview-close
      aria-label="Close preview"
    ></button>

    <div class="wp-lightbox__stage">
      <button
        type="button"
        class="wp-lightbox__close"
        data-preview-close
        aria-label="Close preview"
      >
        ×
      </button>

      <figure class="wp-lightbox__figure">
        <img
          src={src}
          alt={alt}
          class="wp-lightbox__image"
          loading="eager"
          decoding="async"
        />
      </figure>
    </div>
  </div>
</div>

<style>
  .wp-lightbox {
    display: inline-flex;
    align-items: center;
  }

  .wp-lightbox__link {
    appearance: none;
    border: 0;
    background: transparent;
    padding: 0;
    color: #4d647d;
    font-size: 0.82rem;
    font-weight: 700;
    line-height: 1.4;
    letter-spacing: 0.01em;
    cursor: pointer;
    text-decoration: underline;
    text-decoration-color: rgba(77, 100, 125, 0.3);
    text-underline-offset: 0.18em;
    transition:
      color 180ms cubic-bezier(0.22, 1, 0.36, 1),
      text-decoration-color 180ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .wp-lightbox__link:hover {
    color: #17314f;
    text-decoration-color: rgba(23, 49, 79, 0.5);
  }

  .wp-lightbox__overlay[hidden] {
    display: none !important;
  }

  .wp-lightbox__overlay {
    position: fixed;
    inset: 0;
    z-index: 99999;
  }

  .wp-lightbox__backdrop {
    position: absolute;
    inset: 0;
    border: 0;
    background: rgba(7, 13, 22, 0.9);
    backdrop-filter: blur(10px);
    cursor: zoom-out;
  }

  .wp-lightbox__stage {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 32px;
  }

  .wp-lightbox__figure {
    position: relative;
    margin: 0;
    max-width: min(1600px, calc(100vw - 64px));
    max-height: calc(100vh - 64px);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .wp-lightbox__image {
    display: block;
    max-width: 100%;
    max-height: calc(100vh - 64px);
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 18px;
    background: #0a1422;
    box-shadow:
      0 36px 90px rgba(0, 0, 0, 0.42),
      0 12px 30px rgba(0, 0, 0, 0.22);
    transform: scale(0.985);
    opacity: 0;
    transition:
      transform 200ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 200ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .wp-lightbox__overlay.is-open .wp-lightbox__image {
    transform: scale(1);
    opacity: 1;
  }

  .wp-lightbox__close {
    position: absolute;
    top: 18px;
    right: 18px;
    z-index: 2;
    width: 46px;
    height: 46px;
    border: 0;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.96);
    color: #102742;
    font-size: 1.55rem;
    line-height: 1;
    cursor: pointer;
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.2);
    transition:
      transform 180ms cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 180ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .wp-lightbox__close:hover {
    transform: translateY(-1px);
    box-shadow: 0 14px 28px rgba(0, 0, 0, 0.24);
  }

  @media (max-width: 768px) {
    .wp-lightbox__stage {
      padding: 14px;
    }

    .wp-lightbox__figure {
      max-width: calc(100vw - 28px);
      max-height: calc(100vh - 28px);
    }

    .wp-lightbox__image {
      max-height: calc(100vh - 28px);
      border-radius: 14px;
    }

    .wp-lightbox__close {
      top: 10px;
      right: 10px;
      width: 42px;
      height: 42px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .wp-lightbox__image,
    .wp-lightbox__close,
    .wp-lightbox__link {
      transition: none !important;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll("[data-preview-root]").forEach((root) => {
      const openBtn = root.querySelector("[data-preview-open]");
      const overlay = root.querySelector("[data-preview-overlay]");
      const closeBtns = overlay?.querySelectorAll("[data-preview-close]");

      if (!(openBtn instanceof HTMLElement) || !(overlay instanceof HTMLElement)) return;

      if (overlay.parentElement !== document.body) {
        document.body.appendChild(overlay);
      }

      const openModal = () => {
        overlay.hidden = false;
        overlay.classList.add("is-open");
        document.documentElement.style.overflow = "hidden";
        document.body.style.overflow = "hidden";
      };

      const closeModal = () => {
        overlay.classList.remove("is-open");
        overlay.hidden = true;
        document.documentElement.style.overflow = "";
        document.body.style.overflow = "";
      };

      openBtn.addEventListener("click", openModal);

      closeBtns?.forEach((btn) => {
        btn.addEventListener("click", closeModal);
      });

      document.addEventListener("keydown", (event) => {
        if (!overlay.hidden && event.key === "Escape") {
          closeModal();
        }
      });
    });
  });
</script>