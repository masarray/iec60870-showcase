---
interface Props {
  src: string;
  alt?: string;
}
const { src, alt = "" } = Astro.props;
---

<div class="lb-wrap" data-lb>
  <button class="lb-trigger" type="button" data-lb-open aria-label="Open image preview">
    <img src={src} alt={alt} class="lb-image" />
    <span class="lb-hint">Click to enlarge</span>
  </button>

  <div class="lb-modal" data-lb-modal hidden>
    <button class="lb-backdrop" type="button" data-lb-close aria-label="Close image preview"></button>

    <div class="lb-content">
      <button class="lb-close" type="button" data-lb-close aria-label="Close image preview">×</button>
      <img src={src} alt={alt} class="lb-full" />
    </div>
  </div>
</div>

<style>
  .lb-wrap {
    position: relative;
  }

  .lb-trigger {
    position: relative;
    display: block;
    width: 100%;
    padding: 0;
    border: 0;
    background: transparent;
    cursor: zoom-in;
  }

  .lb-image {
    width: 100%;
    display: block;
    border-radius: 18px;
  }

  .lb-hint {
    position: absolute;
    right: 14px;
    bottom: 14px;
    min-height: 28px;
    display: inline-flex;
    align-items: center;
    padding: 0 10px;
    border-radius: 999px;
    background: rgba(9, 21, 37, 0.72);
    color: rgba(245, 250, 255, 0.92);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    pointer-events: none;
  }

  .lb-modal[hidden] {
    display: none;
  }

  .lb-modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
  }

  .lb-backdrop {
    position: absolute;
    inset: 0;
    border: 0;
    background: rgba(8, 16, 28, 0.78);
    backdrop-filter: blur(10px);
    cursor: zoom-out;
  }

  .lb-content {
    position: relative;
    width: min(1180px, calc(100vw - 32px));
    margin: 24px auto;
    z-index: 2;
  }

  .lb-full {
    width: 100%;
    max-height: calc(100vh - 48px);
    object-fit: contain;
    display: block;
    border-radius: 20px;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.32);
    transform: scale(0.975);
    opacity: 0;
    transition:
      transform 220ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .lb-modal:not([hidden]) .lb-full {
    transform: scale(1);
    opacity: 1;
  }

  .lb-close {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 3;
    width: 42px;
    height: 42px;
    border: 0;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.94);
    color: #102742;
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.16);
  }

  @media (max-width: 768px) {
    .lb-hint {
      right: 10px;
      bottom: 10px;
      font-size: 0.68rem;
    }

    .lb-content {
      width: min(100vw - 20px, 1180px);
      margin: 10px auto;
    }

    .lb-full {
      max-height: calc(100vh - 20px);
      border-radius: 16px;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll("[data-lb]").forEach((root) => {
      const modal = root.querySelector("[data-lb-modal]");
      const openBtn = root.querySelector("[data-lb-open]");
      const closeBtns = root.querySelectorAll("[data-lb-close]");

      if (!(modal instanceof HTMLElement) || !(openBtn instanceof HTMLElement)) return;

      const openModal = () => {
        modal.hidden = false;
        document.documentElement.style.overflow = "hidden";
      };

      const closeModal = () => {
        modal.hidden = true;
        document.documentElement.style.overflow = "";
      };

      openBtn.addEventListener("click", openModal);
      closeBtns.forEach((btn) => btn.addEventListener("click", closeModal));

      document.addEventListener("keydown", (event) => {
        if (!modal.hidden && event.key === "Escape") {
          closeModal();
        }
      });
    });
  });
</script>