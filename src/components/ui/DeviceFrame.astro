---
export interface Props {
  src: string;
  alt: string;
  loading?: "lazy" | "eager";
  decoding?: "async" | "auto" | "sync";
  fetchpriority?: "high" | "low" | "auto";
  sizes?: string;
  width?: number;
  height?: number;
}

const {
  src,
  alt,
  loading = "lazy",
  decoding = "async",
  fetchpriority = "auto",
  sizes = "100vw",
  width,
  height
} = Astro.props;
---

<div class="device-frame">
  <div class="device-frame__bezel" aria-hidden="true"></div>
  <div class="device-frame__shine" aria-hidden="true"></div>
  <img
    src={src}
    alt={alt}
    loading={loading}
    decoding={decoding}
    fetchpriority={fetchpriority}
    sizes={sizes}
    width={width}
    height={height}
  />
</div>

<style>
.device-frame {
  position: relative;
  isolation: isolate;
  background:
    linear-gradient(180deg, rgba(251, 253, 255, 0.98), rgba(238, 244, 249, 0.94));
  border: 1px solid rgba(104, 132, 162, 0.18);
  border-radius: 30px;
  padding: 12px;
  box-shadow:
    0 30px 60px rgba(18, 34, 57, 0.1),
    0 10px 22px rgba(18, 34, 57, 0.05),
    inset 0 1px 0 rgba(255, 255, 255, 0.78);
  transition:
    transform 240ms cubic-bezier(0.22, 1, 0.36, 1),
    box-shadow 240ms cubic-bezier(0.22, 1, 0.36, 1),
    border-color 240ms cubic-bezier(0.22, 1, 0.36, 1),
    background 240ms cubic-bezier(0.22, 1, 0.36, 1);
  transform: translateZ(0);
  backface-visibility: hidden;
}

.device-frame::before {
  content: "";
  position: absolute;
  inset: 10px;
  border-radius: 24px;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0)),
    linear-gradient(135deg, rgba(13, 29, 49, 0.08), rgba(13, 29, 49, 0));
  border: 1px solid rgba(255, 255, 255, 0.46);
  pointer-events: none;
  z-index: 0;
}

.device-frame::after {
  content: "";
  position: absolute;
  top: 13px;
  left: 16px;
  right: 16px;
  height: 18px;
  border-radius: 12px 12px 8px 8px;
  background:
    radial-gradient(circle at 18px 9px, rgba(17, 116, 216, 0.42) 0 2.5px, transparent 3.5px),
    radial-gradient(circle at 31px 9px, rgba(24, 183, 200, 0.28) 0 2.5px, transparent 3.5px),
    linear-gradient(180deg, rgba(15, 33, 57, 0.09), rgba(15, 33, 57, 0.01));
  pointer-events: none;
  z-index: 2;
}

.device-frame__bezel {
  position: absolute;
  inset: 11px;
  border-radius: 22px;
  background:
    linear-gradient(180deg, rgba(10, 23, 39, 0.18), rgba(10, 23, 39, 0.04));
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.22),
    inset 0 -18px 28px rgba(14, 28, 45, 0.08);
  pointer-events: none;
  z-index: 1;
}

.device-frame__shine {
  position: absolute;
  inset: 0;
  border-radius: inherit;
  background:
    linear-gradient(115deg, rgba(255, 255, 255, 0.34), rgba(255, 255, 255, 0) 34%);
  opacity: 0.64;
  pointer-events: none;
  z-index: 3;
}

.device-frame:hover {
  transform: translateY(-4px) scale(1.003);
  box-shadow:
    0 34px 66px rgba(18, 34, 57, 0.14),
    0 10px 20px rgba(18, 34, 57, 0.06),
    inset 0 1px 0 rgba(255, 255, 255, 0.84);
  border-color: rgba(17, 116, 216, 0.16);
  background: linear-gradient(180deg, rgba(252,254,255,0.99), rgba(241,246,250,0.97));
}

.device-frame img {
  width: 100%;
  height: auto;
  position: relative;
  z-index: 4;
  border-radius: 18px;
  display: block;
  object-fit: cover;
  transform: translateZ(0);
  backface-visibility: hidden;
  box-shadow:
    0 10px 24px rgba(10, 23, 39, 0.1),
    inset 0 1px 0 rgba(255, 255, 255, 0.08);
}
</style>
