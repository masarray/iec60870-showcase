---
export interface Props {
  src: string;
  alt: string;
  loading?: "lazy" | "eager";
  decoding?: "async" | "auto" | "sync";
  fetchpriority?: "high" | "low" | "auto";
  sizes?: string;
  width?: number;
  height?: number;
}

const {
  src,
  alt,
  loading = "lazy",
  decoding = "async",
  fetchpriority = "auto",
  sizes = "100vw",
  width,
  height
} = Astro.props;
---

<div class="device-frame">
  <div class="device-frame__bezel" aria-hidden="true"></div>
  <div class="device-frame__shine" aria-hidden="true"></div>
  <img
    src={src}
    alt={alt}
    loading={loading}
    decoding={decoding}
    fetchpriority={fetchpriority}
    sizes={sizes}
    width={width}
    height={height}
  />
</div>

<style>
.device-frame {
  position: relative;
  isolation: isolate;
  background:
    linear-gradient(180deg, rgba(244, 249, 253, 0.92), rgba(222, 232, 241, 0.78));
  border: 1px solid rgba(255, 255, 255, 0.34);
  border-radius: 32px;
  padding: 14px;
  box-shadow:
    0 34px 74px rgba(14, 31, 49, 0.12),
    0 10px 24px rgba(14, 31, 49, 0.07),
    inset 0 1px 0 rgba(255, 255, 255, 0.68),
    inset 0 -24px 36px rgba(146, 173, 198, 0.14);
  backdrop-filter: blur(16px) saturate(1.08);
  transition:
    transform 240ms cubic-bezier(0.22, 1, 0.36, 1),
    box-shadow 240ms cubic-bezier(0.22, 1, 0.36, 1),
    border-color 240ms cubic-bezier(0.22, 1, 0.36, 1),
    background 240ms cubic-bezier(0.22, 1, 0.36, 1);
  transform: translateZ(0);
  backface-visibility: hidden;
}

.device-frame::before {
  content: "";
  position: absolute;
  inset: 11px;
  border-radius: 25px;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.22), rgba(255, 255, 255, 0)),
    linear-gradient(135deg, rgba(18, 45, 71, 0.12), rgba(18, 45, 71, 0));
  border: 1px solid rgba(255, 255, 255, 0.3);
  pointer-events: none;
  z-index: 0;
}

.device-frame::after {
  content: "";
  position: absolute;
  top: 13px;
  left: 16px;
  right: 16px;
  height: 18px;
  border-radius: 12px 12px 8px 8px;
  background:
    radial-gradient(circle at 18px 9px, rgba(17, 116, 216, 0.42) 0 2.5px, transparent 3.5px),
    radial-gradient(circle at 31px 9px, rgba(24, 183, 200, 0.28) 0 2.5px, transparent 3.5px),
    linear-gradient(180deg, rgba(15, 33, 57, 0.09), rgba(15, 33, 57, 0.01));
  pointer-events: none;
  z-index: 2;
}

.device-frame__bezel {
  position: absolute;
  inset: 12px;
  border-radius: 23px;
  background:
    linear-gradient(180deg, rgba(7, 19, 33, 0.16), rgba(7, 19, 33, 0.03));
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.18),
    inset 0 -20px 34px rgba(14, 28, 45, 0.1);
  pointer-events: none;
  z-index: 1;
}

.device-frame__shine {
  position: absolute;
  inset: 0;
  border-radius: inherit;
  background:
    linear-gradient(112deg, rgba(255, 255, 255, 0.42), rgba(255, 255, 255, 0.08) 26%, rgba(255, 255, 255, 0) 42%);
  opacity: 0.78;
  pointer-events: none;
  z-index: 3;
}

.device-frame:hover {
  transform: translateY(-4px) scale(1.003);
  box-shadow:
    0 40px 78px rgba(14, 31, 49, 0.16),
    0 12px 22px rgba(14, 31, 49, 0.08),
    inset 0 1px 0 rgba(255, 255, 255, 0.8),
    inset 0 -24px 36px rgba(146, 173, 198, 0.16);
  border-color: rgba(17, 116, 216, 0.16);
  background: linear-gradient(180deg, rgba(248, 252, 255, 0.96), rgba(228, 238, 246, 0.82));
}

.device-frame img {
  width: 100%;
  height: auto;
  position: relative;
  z-index: 4;
  border-radius: 18px;
  display: block;
  object-fit: cover;
  transform: translateZ(0);
  backface-visibility: hidden;
  box-shadow:
    0 14px 28px rgba(10, 23, 39, 0.14),
    inset 0 1px 0 rgba(255, 255, 255, 0.08);
}
</style>
