---
export interface Props {
  src: string;
  alt: string;
  loading?: "lazy" | "eager";
  decoding?: "async" | "auto" | "sync";
  fetchpriority?: "high" | "low" | "auto";
  sizes?: string;
  width?: number;
  height?: number;
}

const {
  src,
  alt,
  loading = "lazy",
  decoding = "async",
  fetchpriority = "auto",
  sizes = "100vw",
  width,
  height
} = Astro.props;
---

<div class="device-frame">
  <img
    src={src}
    alt={alt}
    loading={loading}
    decoding={decoding}
    fetchpriority={fetchpriority}
    sizes={sizes}
    width={width}
    height={height}
  />
</div>

<style>
.device-frame {
  position: relative;
  background: linear-gradient(180deg, rgba(246,249,252,0.98), rgba(238,244,249,0.92));
  border: 1px solid rgba(84, 114, 145, 0.14);
  border-radius: 28px;
  padding: 12px;
  box-shadow:
    0 22px 44px rgba(18, 34, 57, 0.08),
    0 6px 14px rgba(18, 34, 57, 0.05);
  transition:
    transform 240ms cubic-bezier(0.22, 1, 0.36, 1),
    box-shadow 240ms cubic-bezier(0.22, 1, 0.36, 1),
    border-color 240ms cubic-bezier(0.22, 1, 0.36, 1),
    background 240ms cubic-bezier(0.22, 1, 0.36, 1);
  transform: translateZ(0);
  backface-visibility: hidden;
}

.device-frame::before {
  content: "";
  position: absolute;
  top: 12px;
  left: 12px;
  right: 12px;
  height: 22px;
  border-radius: 12px 12px 8px 8px;
  background:
    radial-gradient(circle at 18px 11px, rgba(17, 116, 216, 0.4) 0 3px, transparent 4px),
    radial-gradient(circle at 32px 11px, rgba(24, 183, 200, 0.28) 0 3px, transparent 4px),
    linear-gradient(180deg, rgba(15, 33, 57, 0.08), rgba(15, 33, 57, 0.02));
  pointer-events: none;
}

.device-frame:hover {
  transform: translateY(-3px);
  box-shadow:
    0 26px 52px rgba(18, 34, 57, 0.11),
    0 8px 16px rgba(18, 34, 57, 0.06);
  border-color: rgba(17, 116, 216, 0.14);
  background: linear-gradient(180deg, rgba(248,251,253,0.98), rgba(241,246,250,0.96));
}

.device-frame img {
  width: 100%;
  height: auto;
  position: relative;
  z-index: 1;
  border-radius: 20px;
  display: block;
  object-fit: cover;
  transform: translateZ(0);
  backface-visibility: hidden;
}
</style>
