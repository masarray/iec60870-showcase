---
export interface Props {
  src: string;
  alt: string;
  loading?: "lazy" | "eager";
  decoding?: "async" | "auto" | "sync";
  fetchpriority?: "high" | "low" | "auto";
  sizes?: string;
  width?: number;
  height?: number;
}

const {
  src,
  alt,
  loading = "lazy",
  decoding = "async",
  fetchpriority = "auto",
  sizes = "100vw",
  width,
  height
} = Astro.props;
---

<div class="device-frame">
  <img
    src={src}
    alt={alt}
    loading={loading}
    decoding={decoding}
    fetchpriority={fetchpriority}
    sizes={sizes}
    width={width}
    height={height}
  />
</div>

<style>
.device-frame {
  position: relative;
  background: linear-gradient(180deg, rgba(255,255,255,0.94), rgba(245,250,255,0.92));
  border: 1px solid rgba(104, 145, 188, 0.18);
  border-radius: 24px;
  padding: 14px;
  box-shadow:
    0 20px 50px rgba(32, 74, 121, 0.10),
    0 8px 18px rgba(20, 53, 91, 0.08);
  transition:
    transform 240ms cubic-bezier(0.22, 1, 0.36, 1),
    box-shadow 240ms cubic-bezier(0.22, 1, 0.36, 1),
    border-color 240ms cubic-bezier(0.22, 1, 0.36, 1),
    background 240ms cubic-bezier(0.22, 1, 0.36, 1);
  transform: translateZ(0);
  backface-visibility: hidden;
}

.device-frame:hover {
  transform: translateY(-4px);
  box-shadow:
    0 26px 60px rgba(32, 74, 121, 0.13),
    0 10px 22px rgba(20, 53, 91, 0.10);
  border-color: rgba(41, 184, 255, 0.24);
  background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(247,251,255,0.96));
}

.device-frame img {
  width: 100%;
  height: auto;
  border-radius: 14px;
  display: block;
  object-fit: cover;
  transform: translateZ(0);
  backface-visibility: hidden;
}
</style>