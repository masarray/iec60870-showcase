---
export interface Props {
  src: string;
  alt: string;
  loading?: "lazy" | "eager";
  decoding?: "async" | "auto" | "sync";
  fetchpriority?: "high" | "low" | "auto";
  sizes?: string;
  width?: number;
  height?: number;
}

const {
  src,
  alt,
  loading = "lazy",
  decoding = "async",
  fetchpriority = "auto",
  sizes = "100vw",
  width,
  height
} = Astro.props;
---

<div class="device-frame">
  <img
    src={src}
    alt={alt}
    loading={loading}
    decoding={decoding}
    fetchpriority={fetchpriority}
    sizes={sizes}
    width={width}
    height={height}
  />
</div>

<style>
.device-frame {
  position: relative;
  background: linear-gradient(180deg, rgba(255,255,255,0.96), rgba(244,248,252,0.92));
  border: 1px solid rgba(84, 114, 145, 0.18);
  border-radius: 28px;
  padding: 14px;
  box-shadow:
    0 26px 60px rgba(18, 34, 57, 0.10),
    0 8px 18px rgba(18, 34, 57, 0.06);
  transition:
    transform 240ms cubic-bezier(0.22, 1, 0.36, 1),
    box-shadow 240ms cubic-bezier(0.22, 1, 0.36, 1),
    border-color 240ms cubic-bezier(0.22, 1, 0.36, 1),
    background 240ms cubic-bezier(0.22, 1, 0.36, 1);
  transform: translateZ(0);
  backface-visibility: hidden;
}

.device-frame::before {
  content: "";
  position: absolute;
  inset: 14px 14px auto 14px;
  height: 28px;
  border-radius: 14px 14px 10px 10px;
  background: linear-gradient(180deg, rgba(15, 33, 57, 0.08), rgba(15, 33, 57, 0.02));
  pointer-events: none;
}

.device-frame:hover {
  transform: translateY(-4px);
  box-shadow:
    0 30px 70px rgba(18, 34, 57, 0.13),
    0 10px 22px rgba(18, 34, 57, 0.08);
  border-color: rgba(17, 116, 216, 0.18);
  background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(247,250,253,0.96));
}

.device-frame img {
  width: 100%;
  height: auto;
  position: relative;
  z-index: 1;
  border-radius: 18px;
  display: block;
  object-fit: cover;
  transform: translateZ(0);
  backface-visibility: hidden;
}
</style>
