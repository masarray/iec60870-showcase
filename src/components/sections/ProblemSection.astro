---
import Container from "@/components/layout/Container.astro";
import SectionShell from "@/components/layout/SectionShell.astro";
---

<SectionShell>
  <Container>
    <div class="problem-section" data-reveal>

      <h2 class="problem-title">
        Real-world IEC communication is messy.
      </h2>

      <p class="problem-sub">
        Engineers don't struggle with protocols — they struggle with unclear behavior.
      </p>

      <div class="problem-grid">

        <div class="problem-item">
          Unclear link switching during redundancy
        </div>

        <div class="problem-item">
          Missing or inconsistent SOE timing
        </div>

        <div class="problem-item">
          Command executed but no visible feedback
        </div>

        <div class="problem-item">
          FAT/SAT validation without clear evidence
        </div>

        <div class="problem-item">
          Protocol traces that are hard to interpret
        </div>

      </div>

    </div>
  </Container>
</SectionShell>