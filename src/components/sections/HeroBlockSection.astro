---
import { heroContent } from "@/content/hero";
import Button from "@/components/ui/Button.astro";
import DeviceFrame from "@/components/ui/DeviceFrame.astro";

const assetBase = import.meta.env.BASE_URL;
const heroImageSrc = `${assetBase}${heroContent.heroImage.src}`;
---

<section class="section hero-section" data-hero-root>
  <div class="container hero-container">
    <div class="hero-grid">
      <div class="hero-copy-col">
        <div class="hero-copy">
          <div class="hero-eyebrow" data-reveal>{heroContent.eyebrow}</div>

          <h1 class="hero-title" data-hero-title data-reveal>
            {heroContent.title}
          </h1>

          <p class="hero-tagline" data-hero-copy data-reveal>
            {heroContent.tagline}
          </p>

          <p class="hero-description" data-reveal>
            {heroContent.subtext}
          </p>

          <div class="hero-meta" data-reveal>
            <span>IEC 60870-5-101 / 104</span>
            <span>FAT & Commissioning</span>
            <span>Timeline & Evidence</span>
          </div>

          <div class="hero-actions" data-hero-actions data-reveal>
            <Button href={heroContent.primaryCta.href} variant="primary">
              {heroContent.primaryCta.label}
            </Button>

            <Button href={heroContent.secondaryCta.href} variant="secondary">
              {heroContent.secondaryCta.label}
            </Button>
          </div>

          <div class="hero-trust-strip" data-reveal>
            <div class="trust-item">
              <strong>Built for engineers</strong>
              <span>Designed for FAT, troubleshooting, and field validation.</span>
            </div>
            <div class="trust-item">
              <strong>Readable evidence</strong>
              <span>SOE, command flow, redundancy behavior, and protocol visibility.</span>
            </div>
          </div>
        </div>
      </div>

      <div class="hero-visual" data-hero-visual data-reveal>
        <div class="hero-glow"></div>
        <div class="hero-grid-overlay"></div>

        <div class="hero-device">
          <DeviceFrame
            src={heroImageSrc}
            alt={heroContent.heroImage.alt}
            loading="eager"
            decoding="async"
            fetchpriority="high"
            sizes="(max-width: 900px) 100vw, 58vw"
          />
        </div>
        </div>
      </div>
    </div>
  </div>
</section>