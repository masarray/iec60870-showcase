---
import { heroContent } from "@/content/hero";
import Button from "@/components/ui/Button.astro";
import DeviceFrame from "@/components/ui/DeviceFrame.astro";

const assetBase = import.meta.env.BASE_URL;
const heroImageSrc = `${assetBase}${heroContent.heroImage.src}`;
---

<section class="section hero-section" data-hero-root>
  <div class="container hero-container">
    <div class="hero-grid">
      <div class="hero-copy-col">
        <div class="hero-copy">
          <div class="hero-eyebrow" data-hero-eyebrow>
            {heroContent.eyebrow}
          </div>

          <h1 class="hero-title" data-hero-title>
            {heroContent.title}
          </h1>

          <p class="hero-tagline" data-hero-copy>
            {heroContent.tagline}
          </p>

          <p class="hero-description" data-hero-description>
            {heroContent.subtext}
          </p>

          <div class="hero-proof" data-hero-proof>
            FREE Ľ From engineer to engineer Ľ IEC 60870-5-101 / 104 Ľ Timeline, SOE, Command Proof
          </div>

          <div class="hero-actions" data-hero-actions>
            <Button href={heroContent.primaryCta.href} variant="primary" pulse={true}>
              {heroContent.primaryCta.label}
            </Button>

            <Button href={heroContent.secondaryCta.href} variant="secondary">
              {heroContent.secondaryCta.label}
            </Button>
          </div>
        </div>
      </div>

      <div class="hero-visual-shell" data-hero-visual-shell>
        <div class="hero-visual" data-hero-visual>
          <div class="hero-device">
            <DeviceFrame
              src={heroImageSrc}
              alt={heroContent.heroImage.alt}
              loading="eager"
              decoding="async"
              fetchpriority="high"
              sizes="(max-width: 900px) 100vw, 58vw"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
