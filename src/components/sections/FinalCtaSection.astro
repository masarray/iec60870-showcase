---
import Container from "@/components/layout/Container.astro";
import SectionShell from "@/components/layout/SectionShell.astro";
import Button from "@/components/ui/Button.astro";
import SectionTitle from "@/components/ui/SectionTitle.astro";
import { ctaContent } from "@/content/cta";
---
<SectionShell id="final-cta">
  <Container>
    <div class="final-cta-panel" data-reveal>
      <div class="final-cta-copy">
        <div class="final-cta-kicker">Practical. Focused. Engineer-ready.</div>
        <SectionTitle
          title={ctaContent.title}
          text={ctaContent.description}
        />
      </div>

      <div class="final-cta-actions">
        <Button href={ctaContent.primaryHref} variant="primary" pulse={true}>
          {ctaContent.primaryLabel}
        </Button>
        <Button href={ctaContent.secondaryHref} variant="secondary">
          {ctaContent.secondaryLabel}
        </Button>
      </div>
    </div>
  </Container>
</SectionShell>
