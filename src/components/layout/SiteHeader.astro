---
import { navigationItems } from "@/data/navigation";
import { siteConfig } from "@/content/site";
---

<header class="site-header">
  <div class="container site-header__inner">
    <a class="site-brand" href="#top" aria-label={siteConfig.siteName}>
      <span class="site-brand__mark" aria-hidden="true"></span>
      <span class="site-brand__text">
        <span class="site-brand__title">{siteConfig.siteName}</span>
        <span class="site-brand__meta">Engineering software showcase</span>
      </span>
    </a>

    <div class="site-nav-shell" aria-label="Primary navigation">
      <nav class="site-nav">
        {navigationItems.map((item) => (
          <a href={item.href}>{item.label}</a>
        ))}
      </nav>
    </div>

    <div class="site-header__actions">
      <a class="site-header__cta" href="#final-cta">Book a walkthrough</a>
    </div>
  </div>
</header>