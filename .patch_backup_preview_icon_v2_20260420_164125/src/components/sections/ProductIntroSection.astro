---
import Container from "@/components/layout/Container.astro";
import SectionShell from "@/components/layout/SectionShell.astro";
import SectionTitle from "@/components/ui/SectionTitle.astro";
import DeviceFrame from "@/components/ui/DeviceFrame.astro";
import VisualPreviewTrigger from "@/components/ui/VisualPreviewTrigger.astro";

const assetBase = import.meta.env.BASE_URL;
const introImageSrc = `${assetBase}assets/screenshots/dual-link-trace.png`;
---
<SectionShell id="product-intro">
  <Container>
    <div class="product-intro-grid" data-product-intro>
      <div class="product-intro-copy" data-product-intro-copy>
        <div data-product-intro-heading>
          <SectionTitle
            title="Built to unblock IEC communication work"
            text="A practical analyzer for engineers who need to inspect traffic quickly, understand behavior clearly, and move from communication symptoms to actionable findings."
          />
        </div>

        <div class="product-intro-points" data-product-intro-points>
          <div class="product-intro-point" data-product-intro-point>
            <strong>Simple to read</strong>
            <span>See traffic, timing, and command flow without getting buried in raw frames.</span>
          </div>
          <div class="product-intro-point" data-product-intro-point>
            <strong>Powerful where it matters</strong>
            <span>Handle redundancy analysis, SOE validation, and command diagnostics in one disciplined workflow.</span>
          </div>
        </div>
      </div>

      <div class="product-intro-visual" data-product-intro-visual>
        <DeviceFrame
          src={introImageSrc}
          alt="IEC 60870 analyzer overview"
        />

        <div class="product-intro-preview">
          <VisualPreviewTrigger
            src={introImageSrc}
            alt="IEC 60870 analyzer overview"
            label="Preview"
          />
        </div>
      </div>
    </div>
  </Container>
</SectionShell>

<style>
  .product-intro-visual {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .product-intro-preview {
    width: 100%;
    margin-top: 16px;
    display: flex;
    justify-content: center;
  }

  @media (max-width: 900px) {
    .product-intro-preview {
      margin-top: 12px;
    }
  }
</style>
