---
import Container from "@/components/layout/Container.astro";
import SectionShell from "@/components/layout/SectionShell.astro";
import SectionTitle from "@/components/ui/SectionTitle.astro";
import DeviceFrame from "@/components/ui/DeviceFrame.astro";
import VisualPreviewTrigger from "@/components/ui/VisualPreviewTrigger.astro";
import { featureItems } from "@/content/features";

const [highlight, ...supportItems] = featureItems;
const assetBase = import.meta.env.BASE_URL;
const highlightImageSrc = highlight?.imageSrc ? `${assetBase}${highlight.imageSrc}` : null;
---

<SectionShell id="features">
  <Container>
    <div data-reveal data-capabilities-root>
      <SectionTitle
        title="Core capabilities"
        text="A focused feature set for troubleshooting, validation, event auditing, and communication diagnostics."
      />

      <div class="capabilities-shell">
        {highlight && (
          <div class="capability-highlight" data-hover-lift data-capability-highlight>
            <div class="capability-highlight__copy" data-capability-copy>
              <div class="eyebrow capability-chip" data-capability-eyebrow>{highlight.eyebrow}</div>
              <div class="capability-kicker" data-capability-kicker>Core workflow surface</div>
              <h3 class="capability-highlight__title" data-capability-title>{highlight.title}</h3>
              <p class="section-text capability-highlight__text" data-capability-text>{highlight.description}</p>
            </div>

            <div class="capability-highlight__visual" data-capability-visual>
              {highlightImageSrc ? (
                <>
                  <DeviceFrame
                    src={highlightImageSrc}
                    alt={highlight.title}
                    loading="lazy"
                    decoding="async"
                    sizes="(max-width: 900px) 100vw, 52vw"
                  />

                  <div class="capability-highlight__preview">
                    <VisualPreviewTrigger
                      src={highlightImageSrc}
                      alt={highlight.title}
                      label="Preview"
                    />
                  </div>
                </>
              ) : (
                <div class="capability-highlight__placeholder" aria-hidden="true"></div>
              )}
            </div>
          </div>
        )}

        <div class="summary-grid summary-grid--refined">
          {supportItems.map((item) => (
            <div class="summary-card summary-card--refined" data-hover-lift data-capability-card>
              <div class="eyebrow capability-chip">{item.eyebrow}</div>
              <h3 class="summary-card__title">{item.title}</h3>
              <p class="section-text summary-card__text">{item.description}</p>
              <div class="summary-card__link">Purpose-built for investigation</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </Container>
</SectionShell>

<style>
  .capability-highlight__visual {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .capability-highlight__preview {
    width: 100%;
    margin-top: 16px;
    display: flex;
    justify-content: center;
  }

  @media (max-width: 900px) {
    .capability-highlight__preview {
      margin-top: 12px;
    }
  }
</style>
